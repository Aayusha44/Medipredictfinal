# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for full-stack mode)
DATABASE_URL=postgresql://postgres:password@localhost:5432/medpredict

# ─── Session ──────────────────────────────────────────────────────────────────
# A long, random string used to sign session cookies
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 5000)
PORT=5000
